{
  "manifest_version": 3,
  "name": "Veeva Vault Step Recorder",
  "version": "2.0.0",
  "description": "Records UI interactions on Veeva Vault and exports structured KB JSON for LLM prompt generation",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
