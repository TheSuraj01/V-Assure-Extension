# ═══════════════════════════════════════════════════════════════
# V-Assure Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for local development.
# In production, use encrypted config files or inject via Docker/K8s.

# ── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# DEBUG=false

# ── LLM Provider: Groq ──────────────────────────────────────
GROQ_API_KEY=

# ── LLM Provider: Local (OpenAI-compatible) ─────────────────
LOCAL_API_BASE=
LOCAL_API_KEY=

# ── LLM Provider: AWS Bedrock ───────────────────────────────
# BEDROCK_CREDENTIALS=access_key:secret_key:region

# ── AWS S3 (Excel template source) ──────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_KEY=dynamic_step_patterns.xlsx
# S3_ENDPOINT_URL=           # For S3-compatible services (MinIO, etc.)

# ── Admin ────────────────────────────────────────────────────
ADMIN_SYNC_CODE=

# ── Knowledge Base ───────────────────────────────────────────
# KB_DATA_DIR=data

# ── Pattern Cache ────────────────────────────────────────────
# PATTERNS_CACHE_PATH=config/patterns_cache.json

# ── Encrypted Configuration (Production) ─────────────────────
# CONFIG_FILE_PATH=/etc/vassure/config.enc
# CONFIG_ENCRYPTION_KEY=        # 32-byte hex-encoded AES key

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * only in development.
# CORS_ORIGINS=https://your-domain.com
