# ═══════════════════════════════════════════════════════════════
# V-Assure Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for local development.
# In production, inject secrets via server environment setup or Docker/K8s.

# ── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# DEBUG=false

# ── LLM Provider: Groq ──────────────────────────────────────
GROQ_API_KEY=

# ── LLM Provider: Local (OpenAI-compatible) ─────────────────
LOCAL_API_BASE=
LOCAL_API_KEY=

# ── LLM Provider: AWS Bedrock ───────────────────────────────
# BEDROCK_CREDENTIALS=access_key:secret_key:region

# ── S3 Proxy API (Excel template source) ────────────────────
# Base URL of the lightweight S3 REST proxy
S3_API_BASE_URL=http://172.27.222.7:8080
S3_BUCKET=spotline-vassure
S3_KEY=dynamic_step_patterns.xlsx

# ── Admin ────────────────────────────────────────────────────
ADMIN_SYNC_CODE=

# ── Knowledge Base ───────────────────────────────────────────
# KB_DATA_DIR=data

# ── Pattern Cache ────────────────────────────────────────────
# PATTERNS_CACHE_PATH=config/patterns_cache.json

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * only in development.
# CORS_ORIGINS=https://your-domain.com
